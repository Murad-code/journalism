# PostgreSQL (use host "postgres" when running the stack with docker-compose)
DATABASE_URL=postgres://payload:payload@postgres:5432/journalism

# Local development without Docker (example):
# DATABASE_URL=postgresql://payload:payload@127.0.0.1:5432/journalism

# Used to encrypt JWT tokens and sessions
PAYLOAD_SECRET=replace-with-a-long-random-string

# Public site URL — no trailing slash (CORS, links, OG images)
NEXT_PUBLIC_SERVER_URL=http://localhost

# Optional: Payload draft preview (must match the secret sent to /next/preview)
PREVIEW_SECRET=replace-with-a-long-random-string

# Optional: authorize scheduled jobs / cron hitting Payload (Bearer token)
CRON_SECRET=replace-with-a-long-random-string

# Optional: align with DATABASE_URL credentials when using docker-compose defaults
POSTGRES_USER=payload
POSTGRES_PASSWORD=payload
POSTGRES_DB=journalism
