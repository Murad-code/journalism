# Copy to `.env` and fill in values. Do not commit `.env`.
# For Docker Hub images: bake only non-secrets at build (e.g. NEXT_PUBLIC_SERVER_URL);
# pass secrets at container runtime on the VPS.

# --- Runtime (required in production) ---
# Postgres connection (Payload). On VPS, point at your DB host (often a service name like `postgres:5432`).
DATABASE_URL=postgres://user:password@host:5432/database

# Payload signing secret (min 32 characters). Generate a strong random value for production.
PAYLOAD_SECRET=

# Public site URL (used in URLs, CORS, and client bundles when set at build time).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Runtime (optional) ---
# Draft preview token (must match the secret configured in the admin preview URL).
PREVIEW_SECRET=

# Bearer token for job runner / cron HTTP calls when no user session.
CRON_SECRET=

# --- Local docker-compose Postgres (optional overrides) ---
POSTGRES_USER=payload
POSTGRES_PASSWORD=payload
POSTGRES_DB=journalism
# Host port mapped to Postgres (see docker-compose.yml). Use this in DATABASE_URL from your machine, e.g.:
# DATABASE_URL=postgres://payload:payload@127.0.0.1:5433/journalism
POSTGRES_HOST_PORT=5433

# --- Docker image build (local) ---
# 1. `docker compose up -d postgres`
# 2. Apply schema: `DATABASE_URL=postgres://payload:payload@127.0.0.1:${POSTGRES_HOST_PORT:-5433}/journalism` plus PAYLOAD_SECRET → `pnpm payload migrate`
# 3. If `docker compose build app` fails with BuildKit / network:service:postgres, use legacy Docker build:
#    PG=$(docker compose ps -q postgres); DOCKER_BUILDKIT=0 docker build --network=container:$PG \
#      --build-arg DATABASE_URL=postgres://payload:payload@127.0.0.1:5432/journalism \
#      --build-arg PAYLOAD_SECRET=your-32+char-build-placeholder \
#      --build-arg NEXT_PUBLIC_SERVER_URL=https://your-domain.com \
#      -t youruser/journalism:tag .
